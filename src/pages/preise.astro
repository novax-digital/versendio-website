---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import SectionHead from '../components/SectionHead.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';
import { SITE } from '../data/site';
import {
  PRICES,
  LETTER_TIERS,
  EXTRA_SHEET,
  VARIANT_LABELS,
  VARIANT_ORDER,
  formatEuro,
  gross,
} from '../data/pricing';

const title = `Preise: Briefe online versenden ab ${formatEuro(PRICES.standardLetter)} – Pay as you go | versendio`;
const description = `Transparente Preise ohne Grundgebühr: Standardbrief ab ${formatEuro(PRICES.standardLetter)} netto inkl. Porto, Druck & Kuvertierung. Kein Abo, keine Mindestmenge – Sie zahlen nur, was Sie versenden.`;

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Preise', item: `${SITE.url}/preise` },
  ],
};

const productLd = {
  '@type': 'Product',
  '@id': `${SITE.url}/preise#briefversand`,
  name: 'versendio Briefversand',
  description:
    'Online-Briefversand mit Druck, Kuvertierung, Porto und Zustellung – Pay as you go ohne Grundgebühr.',
  brand: { '@type': 'Brand', name: 'versendio' },
  offers: {
    '@type': 'Offer',
    url: `${SITE.url}/preise`,
    priceCurrency: 'EUR',
    price: PRICES.standardLetter.toFixed(2),
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: PRICES.standardLetter.toFixed(2),
      priceCurrency: 'EUR',
      valueAddedTaxIncluded: false,
      unitText: 'Brief',
    },
    availability: 'https://schema.org/InStock',
  },
};

const included = [
  'Porto & Zustellung (Deutsche Post)',
  'Professioneller Druck in Graustufen',
  'Falzen & maschinelle Kuvertierung',
  'Sendungsstatus im Dashboard',
  'Beleg für Ihre Buchhaltung',
];

const sheetOptions = VARIANT_ORDER.map((variant) => ({
  name: `Weiteres Blatt – ${VARIANT_LABELS[variant]}`,
  price: EXTRA_SHEET[variant],
}));

// Beispielrechnungen mit echten Preisen
const invoiceExample = LETTER_TIERS[0].prices.bwSimplex + EXTRA_SHEET.bwSimplex; // Standardbrief, 2 Blatt s/w
const mailingExample = LETTER_TIERS[0].prices.colorSimplex * 250; // 250 × Standardbrief Farbe
const reportExample = LETTER_TIERS[2].prices.bwDuplex + 9 * EXTRA_SHEET.bwDuplex; // Großbrief, 10 Blatt duplex

const examples = [
  {
    title: 'Rechnung: 2 Blatt s/w, einseitig',
    calc: `${formatEuro(LETTER_TIERS[0].prices.bwSimplex)} + 1 × ${formatEuro(EXTRA_SHEET.bwSimplex)}`,
    net: invoiceExample,
  },
  {
    title: 'Mailing: 250 Briefe, 1 Blatt Farbe',
    calc: `250 × ${formatEuro(LETTER_TIERS[0].prices.colorSimplex)}`,
    net: mailingExample,
  },
  {
    title: 'Bericht: 10 Blatt s/w, beidseitig',
    calc: `${formatEuro(LETTER_TIERS[2].prices.bwDuplex)} + 9 × ${formatEuro(EXTRA_SHEET.bwDuplex)}`,
    net: reportExample,
  },
] as const;

const faqItems = [
  {
    q: 'Gibt es eine Grundgebühr oder ein Abo?',
    a: 'Nein. versendio ist komplett Pay as you go: keine Grundgebühr, kein Abo, keine Mindestmenge. Sie laden Guthaben auf und zahlen ausschließlich für tatsächlich versendete Briefe.',
  },
  {
    q: 'Sind die Preise netto oder brutto?',
    a: `Alle angegebenen Preise sind Netto-Preise. Bei der Bezahlung kommen 19 % Umsatzsteuer hinzu, die auf der Rechnung sauber ausgewiesen wird – ein Standardbrief für ${formatEuro(PRICES.standardLetter)} netto kostet also ${formatEuro(gross(PRICES.standardLetter))} brutto.`,
  },
  {
    q: 'Welche Briefart wird für meine Sendung berechnet?',
    a: 'versendio wählt automatisch die passende Briefart nach Umfang Ihrer Sendung: Standardbrief für die klassische Geschäftspost, Kompaktbrief für mittlere und Großbrief für umfangreiche Sendungen. Der exakte Preis wird Ihnen vor dem Versand angezeigt.',
  },
  {
    q: 'Wie lade ich Guthaben auf?',
    a: 'Bequem per Kreditkarte oder SEPA-Lastschrift, sicher abgewickelt über den Zahlungsdienstleister Stripe. Optional aktivieren Sie die automatische Aufladung: Fällt Ihr Guthaben unter einen Schwellwert, wird automatisch nachgeladen.',
  },
  {
    q: 'Verfällt mein Guthaben?',
    a: 'Ihr Guthaben bleibt Ihrem Konto erhalten und wird mit jedem Versand verrechnet. Details regeln unsere AGB.',
  },
  {
    q: 'Erhalte ich Rechnungen für meine Buchhaltung?',
    a: 'Ja. Zu jeder Aufladung erhalten Sie einen Beleg mit ausgewiesener Umsatzsteuer, und in der Transaktionsübersicht sehen Sie jede einzelne Sendung – ideal für die Buchhaltung.',
  },
  {
    q: 'Was kostet ein Mailing an viele Empfänger?',
    a: `Sie zahlen einfach je Brief – ein Mailing an 250 Empfänger mit einem farbigen Blatt kostet z. B. 250 × ${formatEuro(LETTER_TIERS[0].prices.colorSimplex)} = ${formatEuro(mailingExample)} netto. Für regelmäßig große Volumen sprechen Sie uns gern an: info@versendio.de.`,
  },
];
---

<BaseLayout title={title} description={description} jsonLd={[breadcrumbLd, productLd]}>
  <section class="page-hero">
    <div class="container">
      <SectionHead
        as="h1"
        eyebrow="Preise"
        title="Sie zahlen nur, <em>was Sie versenden</em>"
        lead="Keine Grundgebühr, kein Abo, keine Mindestmenge. Ein Preis pro Brief – Porto, Druck und Kuvertierung inklusive. Alle Preise netto zzgl. 19 % USt."
      />
    </div>
  </section>

  <section class="section pricing-main">
    <div class="container pricing-grid">
      <!-- Hauptpreis -->
      <div class="price-card hero-card">
        <span class="pc-badge badge">Am beliebtesten</span>
        <h2>Standardbrief</h2>
        <p class="pc-sub">1 Blatt, s/w einseitig – die klassische Geschäftspost</p>
        <p class="pc-price">
          <span class="value">{formatEuro(PRICES.standardLetter)}</span>
          <span class="unit">netto / Brief</span>
        </p>
        <p class="pc-gross">= {formatEuro(gross(PRICES.standardLetter))} inkl. 19 % USt.</p>
        <ul class="pc-list">
          {
            included.map((item) => (
              <li>
                <Icon name="check" size={17} strokeWidth={2.5} />
                {item}
              </li>
            ))
          }
        </ul>
        <a class="btn btn-primary btn-lg pc-cta" href={SITE.appRegister} rel="noopener">
          Kostenlos starten
        </a>
        <p class="pc-note">Kostenlos registrieren – bezahlt wird erst beim Versand.</p>
      </div>

      <!-- Blattpreise -->
      <div class="options">
        <h2 class="options-title">Mehr Seiten? Nur Cent-Beträge.</h2>
        <p class="options-lead">
          Das erste Blatt ist im Briefpreis enthalten – jedes weitere kostet:
        </p>
        <div class="option-list">
          {
            sheetOptions.map((opt) => (
              <div class="option card">
                <span class="opt-icon"><Icon name="file-text" size={20} /></span>
                <div class="opt-body">
                  <span class="opt-name">{opt.name}</span>
                  <span class="opt-note">je zusätzlichem Blatt</span>
                </div>
                <span class="opt-price">+ {formatEuro(opt.price)}</span>
              </div>
            ))
          }
        </div>
        <p class="options-note">
          <Icon name="info" size={16} />
          versendio wählt automatisch die passende Briefart (Standard, Kompakt
          oder Groß) für Ihren Umfang – der exakte Preis wird vor dem Versand
          transparent angezeigt.
        </p>
      </div>
    </div>
  </section>

  <!-- Briefarten-Matrix -->
  <section class="section section-soft">
    <div class="container">
      <SectionHead
        eyebrow="Preisliste"
        title="Alle Briefarten im Überblick"
        lead="Netto-Preise je Brief inklusive 1 Blatt, Porto, Druck und Kuvertierung – wählbar in Graustufen (s/w) oder Farbe, ein- oder beidseitig bedruckt."
      />
      <div class="matrix-wrap card">
        <table class="matrix">
          <caption class="visually-hidden">
            Preisliste: Briefarten und Druckvarianten (Netto-Preise je Brief)
          </caption>
          <thead>
            <tr>
              <th scope="col">Briefart</th>
              {VARIANT_ORDER.map((variant) => <th scope="col">{VARIANT_LABELS[variant]}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              LETTER_TIERS.map((tier) => (
                <tr>
                  <th scope="row">
                    <span class="tier-name">{tier.name}</span>
                    <span class="tier-note">{tier.note}</span>
                  </th>
                  {VARIANT_ORDER.map((variant) => (
                    <td>{formatEuro(tier.prices[variant])}</td>
                  ))}
                </tr>
              ))
            }
            <tr class="extra-row">
              <th scope="row">
                <span class="tier-name">Je weiteres Blatt</span>
                <span class="tier-note">ab dem 2. Blatt</span>
              </th>
              {VARIANT_ORDER.map((variant) => <td>+ {formatEuro(EXTRA_SHEET[variant])}</td>)}
            </tr>
          </tbody>
        </table>
      </div>
      <p class="matrix-note">
        Alle Preise netto zzgl. 19 % USt. · Stand Juli 2026
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Beispiele"
        title="So rechnet sich <em>Pay as you go</em>"
        lead="Drei typische Sendungen, ehrlich durchgerechnet – ohne versteckte Kosten."
      />
      <div class="examples">
        {
          examples.map((ex) => (
            <div class="example card">
              <h3>{ex.title}</h3>
              <p class="ex-calc">{ex.calc}</p>
              <p class="ex-net">{formatEuro(ex.net)} <span>netto</span></p>
              <p class="ex-gross">{formatEuro(gross(ex.net))} inkl. USt.</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <SectionHead
        eyebrow="Guthaben"
        title="So funktioniert die Abrechnung"
      />
      <ol class="how-billing">
        <li class="card">
          <span class="hb-icon"><Icon name="wallet" size={24} /></span>
          <h3>1. Guthaben aufladen</h3>
          <p>10, 25, 50, 100 € oder Wunschbetrag – per Karte oder SEPA-Lastschrift über Stripe.</p>
        </li>
        <li class="card">
          <span class="hb-icon"><Icon name="send" size={24} /></span>
          <h3>2. Briefe versenden</h3>
          <p>Jeder Versand wird zum Netto-Preis vom Guthaben abgebucht – einzeln nachvollziehbar.</p>
        </li>
        <li class="card">
          <span class="hb-icon"><Icon name="refresh" size={24} /></span>
          <h3>3. Automatisch nachladen</h3>
          <p>Optional: Fällt das Guthaben unter Ihren Schwellwert, lädt versendio automatisch nach.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="container">
      <SectionHead eyebrow="FAQ" title="Häufige Fragen zu den Preisen" />
      <FAQ items={faqItems} />
    </div>
  </section>

  <CTABand
    title="Erst testen, dann zahlen."
    text="Die Registrierung ist kostenlos. Guthaben laden Sie erst auf, wenn Sie wirklich versenden möchten."
  />
</BaseLayout>

<style>
  .page-hero {
    padding: clamp(3rem, 2rem + 3vw, 5rem) 0 0;
    background:
      radial-gradient(700px 420px at 50% -20%, var(--blue-050) 0%, transparent 65%),
      linear-gradient(180deg, #fdfdff 0%, #ffffff 100%);
  }
  .page-hero :global(.section-head) {
    margin-bottom: 1rem;
  }

  .pricing-main {
    padding-top: clamp(2rem, 1.5rem + 2vw, 3.5rem);
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: clamp(1.6rem, 1.2rem + 2vw, 3rem);
    align-items: start;
  }

  /* Hauptpreis-Karte */
  .price-card {
    position: relative;
    background: #fff;
    border: 2px solid var(--blue);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-lg);
    padding: clamp(1.8rem, 1.5rem + 1.5vw, 2.8rem);
  }
  .pc-badge {
    position: absolute;
    top: -0.85rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--blue);
    color: #fff;
    border-color: var(--blue);
  }
  .price-card h2 {
    margin-bottom: 0.15em;
  }
  .pc-sub {
    color: var(--slate-500);
    margin-bottom: 1.4rem;
  }
  .pc-price {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0;
  }
  .pc-price .value {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: clamp(2.8rem, 2.2rem + 2vw, 3.8rem);
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
  }
  .pc-price .unit {
    color: var(--slate-500);
    font-size: 1rem;
  }
  .pc-gross {
    color: var(--slate-500);
    font-size: 0.92rem;
    margin: 0.5rem 0 1.6rem;
  }
  .pc-list {
    list-style: none;
    padding: 1.4rem 0 0;
    margin: 0 0 1.8rem;
    border-top: 1px solid var(--slate-100);
    display: grid;
    gap: 0.65rem;
  }
  .pc-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--slate-700);
  }
  .pc-list :global(svg) {
    color: var(--green-600);
    flex-shrink: 0;
  }
  .pc-cta {
    width: 100%;
  }
  .pc-note {
    text-align: center;
    font-size: 0.88rem;
    color: var(--slate-500);
    margin: 0.8rem 0 0;
  }

  /* Blattpreise */
  .options-title {
    font-size: 1.25rem;
    margin-bottom: 0.3rem;
  }
  .options-lead {
    color: var(--slate-600);
    margin-bottom: 1.1rem;
  }
  .option-list {
    display: grid;
    gap: 0.8rem;
  }
  .option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
  }
  .opt-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 10px;
    background: var(--blue-050);
    border: 1px solid var(--blue-100);
    color: var(--blue);
    flex-shrink: 0;
  }
  .opt-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .opt-name {
    font-family: var(--font-head);
    font-weight: 600;
    color: var(--ink);
  }
  .opt-note {
    font-size: 0.86rem;
    color: var(--slate-500);
  }
  .opt-price {
    margin-left: auto;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--ink);
    white-space: nowrap;
  }
  .options-note {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    margin-top: 1.2rem;
    font-size: 0.92rem;
    color: var(--slate-500);
  }
  .options-note :global(svg) {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Briefarten-Matrix */
  .matrix-wrap {
    overflow-x: auto;
    padding: 0.4rem;
  }
  .matrix {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
    font-size: 0.99rem;
  }
  .matrix th,
  .matrix td {
    padding: 0.95rem 1.1rem;
    text-align: right;
    border-bottom: 1px solid var(--slate-100);
    white-space: nowrap;
  }
  .matrix thead th {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--slate-600);
    background: var(--slate-050);
  }
  .matrix thead th:first-child {
    border-top-left-radius: 10px;
  }
  .matrix thead th:last-child {
    border-top-right-radius: 10px;
  }
  .matrix th[scope='row'],
  .matrix thead th:first-child {
    text-align: left;
  }
  .matrix tbody td {
    font-family: var(--font-head);
    font-weight: 600;
    color: var(--ink);
  }
  .matrix tbody tr:last-child th,
  .matrix tbody tr:last-child td {
    border-bottom: none;
  }
  .tier-name {
    display: block;
    font-family: var(--font-head);
    font-weight: 600;
    color: var(--ink);
  }
  .tier-note {
    display: block;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--slate-500);
  }
  .extra-row {
    background: var(--blue-050);
  }
  .extra-row td {
    color: var(--blue-deep);
  }
  .matrix-note {
    text-align: center;
    font-size: 0.9rem;
    color: var(--slate-500);
    margin: 1.1rem 0 0;
  }

  /* Beispiele */
  .examples {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.3rem;
  }
  .example {
    padding: 1.7rem 1.5rem;
    text-align: center;
  }
  .example h3 {
    font-size: 1.05rem;
    min-height: 2.6em;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ex-calc {
    font-size: 0.9rem;
    color: var(--slate-500);
    margin-bottom: 1rem;
  }
  .ex-net {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 2rem;
    color: var(--blue);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .ex-net span {
    font-size: 0.95rem;
    color: var(--slate-500);
    font-weight: 400;
  }
  .ex-gross {
    font-size: 0.88rem;
    color: var(--slate-400);
    margin: 0.3rem 0 0;
  }
  @media (max-width: 860px) {
    .examples {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
    .example h3 {
      min-height: 0;
    }
  }

  /* Abrechnung */
  .how-billing {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.3rem;
  }
  .how-billing li {
    padding: 1.8rem 1.6rem;
  }
  .hb-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.1rem;
    height: 3.1rem;
    border-radius: 13px;
    background: linear-gradient(135deg, var(--blue) 0%, var(--blue-deep) 100%);
    color: #fff;
    box-shadow: var(--shadow-blue);
    margin-bottom: 1.1rem;
  }
  .how-billing h3 {
    font-size: 1.08rem;
    margin-bottom: 0.35rem;
  }
  .how-billing p {
    font-size: 0.97rem;
    color: var(--slate-600);
    margin: 0;
  }
  @media (max-width: 860px) {
    .how-billing {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
