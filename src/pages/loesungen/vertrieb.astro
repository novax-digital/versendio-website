---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import SectionHead from '../../components/SectionHead.astro';
import FeatureSplit from '../../components/FeatureSplit.astro';
import FAQ from '../../components/FAQ.astro';
import CTABand from '../../components/CTABand.astro';
import MockContacts from '../../components/mockups/MockContacts.astro';
import MockFlow from '../../components/mockups/MockFlow.astro';
import MockDashboard from '../../components/mockups/MockDashboard.astro';
import { SITE } from '../../data/site';

const title = 'versendio im Vertrieb: Briefe als Türöffner & Follow-up-Flows | versendio';
const description =
  'Mehr Termine im Sales: Adresslisten per Brief anschreiben und warm nachtelefonieren, mehrstufige Briefstrecken mit Flows automatisieren und die Zustellung live monitoren – mit versendio.';

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Lösungen', item: `${SITE.url}/loesungen` },
    { '@type': 'ListItem', position: 3, name: 'Vertrieb & Sales', item: `${SITE.url}/loesungen/vertrieb` },
  ],
};

const steps = [
  {
    icon: 'upload',
    title: 'Adressliste importieren',
    text: 'Zielkunden aus CRM, Leadrecherche oder Messe-Kontakten als CSV/Excel importieren. Platzhalter wie {Anrede} und {Firma} machen jeden Brief persönlich.',
  },
  {
    icon: 'send',
    title: 'Anschreiben versenden',
    text: 'Ein Serienbrief an die ganze Liste – gedruckt, kuvertiert und zugestellt, ohne dass jemand am Drucker steht.',
  },
  {
    icon: 'phone',
    title: 'Warm nachfassen',
    text: 'Der Sendungsstatus zeigt, wann die Briefe zugestellt sind – der perfekte Moment, um zum Hörer zu greifen.',
  },
] as const;

const faqItems = [
  {
    q: 'Warum Briefe statt kalter E-Mail-Akquise?',
    a: 'Ein Brief landet nicht im Spam-Ordner, wird geöffnet und bleibt auf dem Schreibtisch liegen. Zudem gilt postalische Werbung rechtlich als deutlich unkritischer als E-Mail-Kaltakquise – im Zweifel klären Sie die Details Ihrer Kampagne mit Ihrer Rechtsberatung.',
  },
  {
    q: 'Wie viele Briefe kann ich gleichzeitig versenden?',
    a: 'Vom einzelnen Anschreiben bis zum Serienbrief an hunderte Empfänger – der exakte Preis pro Brief steht fest, bevor Sie auf „Versenden“ klicken.',
  },
  {
    q: 'Kann ich versendio an unser CRM anbinden?',
    a: 'Ja. Über die REST-API verbinden Sie versendio mit Ihren Systemen – z. B. HubSpot, Zapier, Make oder eigene Software. Neue Leads landen so automatisch in Kontaktlisten und starten dort hinterlegte Flows.',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={[breadcrumbLd]}>
  <section class="page-hero">
    <div class="container">
      <SectionHead
        as="h1"
        eyebrow="Lösungen · Vertrieb & Sales"
        title="Der Brief als <em>Türöffner</em> im Vertrieb"
        lead="Postfächer sind überfüllt, Briefkästen nicht. Vertriebsteams nutzen versendio, um Zielkunden vor dem Erstkontakt anzuschreiben, in mehreren Stufen nachzufassen – und genau zu wissen, wann der richtige Moment für den Anruf ist."
      />
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href={SITE.appRegister} rel="noopener">
          Kostenlos starten <Icon name="arrow-right" size={19} />
        </a>
        <a class="btn btn-secondary btn-lg" href="/preise">Preise ansehen</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="So funktioniert’s"
        title="Von der Leadliste zum Termin – <em>in drei Schritten</em>"
      />
      <ol class="steps">
        {
          steps.map((step, i) => (
            <li class="step card">
              <span class="step-num">{i + 1}</span>
              <span class="step-icon"><Icon name={step.icon} size={26} /></span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container feature-stack">
      <FeatureSplit
        eyebrow="Leadlisten"
        title="Vom Excel-Export zum persönlichen Anschreiben"
        text="Importieren Sie Ihre Zielkunden als CSV- oder Excel-Datei. Platzhalter wie {Anrede}, {Firma} und {Ort} personalisieren jedes Anschreiben automatisch – hunderte Briefe wirken wie einzeln geschrieben."
        bullets={[
          '<strong>CSV/Excel-Import</strong> mit automatischer Feld-Zuordnung',
          '<strong>Kontaktlisten</strong> je Kampagne, Region oder Branche',
          '<strong>Serienbrief:</strong> ein Klick versendet an die ganze Liste',
        ]}
        linkHref="/funktionen#kontakte"
        linkLabel="Mehr zu Kontakten & Listen"
      >
        <MockContacts />
      </FeatureSplit>

      <FeatureSplit
        reverse
        eyebrow="Follow-up-Flows"
        title="Mehrstufig nachfassen – vollautomatisch"
        text="Ein einzelner Brief ist gut, eine Strecke ist besser: Mit Flows erhält jeder neue Kontakt einer Liste automatisch Post. Über mehrere Flows mit unterschiedlichen Wartezeiten bauen Sie ganze Briefstrecken – Vorstellung, Erinnerung, letztes Angebot."
        bullets={[
          '<strong>Mehrere Briefe</strong> in frei gewählten Zeitabständen – z. B. Tag 1, Tag 14, Tag 30',
          '<strong>Automatischer Start:</strong> neue Leads lösen die Strecke aus – auch per REST-API aus dem CRM',
          '<strong>Je Stufe fest hinterlegt:</strong> Briefvorlage, Druckoptionen und Absender',
        ]}
        linkHref="/funktionen#flows"
        linkLabel="Mehr zu Flows"
      >
        <MockFlow />
      </FeatureSplit>

      <FeatureSplit
        eyebrow="Monitoring"
        title="Wissen, was ankommt – und wann"
        text="Jede Sendung hat einen Live-Status: vom Druck bis zur Zustellung. So sehen Sie, welche Briefe unterwegs sind, und timen Ihre Anrufe auf den Moment, in dem Ihr Schreiben auf dem Schreibtisch liegt."
        bullets={[
          '<strong>Sendungsstatus</strong> je Empfänger live im Dashboard',
          '<strong>Kampagne im Blick:</strong> Anzahl, Kosten und Verlauf jeder Aussendung',
          '<strong>Transaktionen & Belege</strong> für sauberes Vertriebs-Reporting',
        ]}
      >
        <MockDashboard />
      </FeatureSplit>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead eyebrow="FAQ" title="Häufige Fragen aus dem Vertrieb" />
      <FAQ items={faqItems} />
    </div>
  </section>

  <CTABand
    title="Ihr nächster Pitch beginnt im Briefkasten."
    text="Importieren Sie Ihre erste Leadliste und versenden Sie Ihr Anschreiben noch heute – ohne Abo, ohne Mindestmenge."
  />
</BaseLayout>

<style>
  .page-hero {
    padding: clamp(3rem, 2rem + 3vw, 5rem) 0 clamp(1rem, 1rem + 1vw, 2rem);
    background:
      radial-gradient(700px 420px at 50% -20%, var(--blue-050) 0%, transparent 65%),
      linear-gradient(180deg, #fdfdff 0%, #ffffff 100%);
  }
  .page-hero :global(.section-head) {
    margin-bottom: 1.8rem;
  }
  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
    padding: 0;
    margin: 0;
  }
  .step {
    position: relative;
    padding: 2rem 1.6rem 1.7rem;
  }
  .step-num {
    position: absolute;
    top: 1.4rem;
    right: 1.5rem;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 2.6rem;
    line-height: 1;
    color: var(--slate-100);
  }
  .step-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--blue) 0%, var(--blue-deep) 100%);
    color: #fff;
    box-shadow: var(--shadow-blue);
    margin-bottom: 1.2rem;
  }
  .step h3 {
    margin-bottom: 0.4rem;
  }
  .step p {
    font-size: 0.99rem;
    color: var(--slate-600);
    margin: 0;
  }
  @media (max-width: 900px) {
    .steps {
      grid-template-columns: 1fr;
      max-width: 560px;
      margin-inline: auto;
    }
  }

  .feature-stack {
    display: grid;
    gap: clamp(4rem, 3rem + 4vw, 7rem);
  }
</style>
