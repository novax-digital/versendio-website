---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import Icon from '../../components/Icon.astro';
import { SITE, COMPANY } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 3);

const dateFmt = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const words = (post.body ?? '').split(/\s+/).length;
const readingTime = Math.max(2, Math.round(words / 200));

// 1200×630-Variante des Covers für Social Cards
const ogCover = await getImage({
  src: post.data.cover,
  width: 1200,
  height: 630,
  fit: 'cover',
  format: 'jpg',
});

const canonicalUrl = `${SITE.url}/blog/${post.id}`;

const blogPostingLd = {
  '@type': 'BlogPosting',
  '@id': `${canonicalUrl}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  headline: post.data.title,
  description: post.data.description,
  image: new URL(ogCover.src, Astro.site).toString(),
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: `${SITE.name} Redaktion`,
    url: SITE.url,
  },
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'de-DE',
  keywords: post.data.tags.join(', '),
  wordCount: words,
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalUrl },
  ],
};
---

<BaseLayout
  title={`${post.data.title} | versendio Blog`}
  description={post.data.description}
  ogImage={ogCover.src}
  ogType="article"
  jsonLd={[blogPostingLd, breadcrumbLd]}
>
  <article class="article">
    <header class="article-head">
      <div class="container-narrow">
        <nav class="crumbs" aria-label="Brotkrumen">
          <a href="/">Start</a>
          <span aria-hidden="true">/</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">/</span>
          <span class="current">{post.data.category}</span>
        </nav>
        <h1>{post.data.title}</h1>
        <p class="article-meta">
          <span class="cat">{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {dateFmt.format(post.data.pubDate)}
          </time>
          <span class="dot">·</span>
          <span>{readingTime} Min. Lesezeit</span>
          <span class="dot">·</span>
          <span>{SITE.name} Redaktion</span>
        </p>
      </div>
    </header>

    <div class="container-narrow">
      <figure class="article-cover">
        <Image
          src={post.data.cover}
          alt={post.data.coverAlt}
          widths={[640, 960, 1400]}
          sizes="(max-width: 800px) 100vw, 760px"
          loading="eager"
          fetchpriority="high"
        />
      </figure>

      <div class="prose article-prose">
        <Content />
      </div>

      {
        post.data.faq && post.data.faq.length > 0 && (
          <section class="article-faq">
            <h2>Häufige Fragen</h2>
            <FAQ items={post.data.faq} />
          </section>
        )
      }

      <aside class="article-cta card">
        <div>
          <h2>Briefe versenden, ohne das Haus zu verlassen</h2>
          <p>
            Mit versendio erstellen Sie Briefe online, wir übernehmen Druck,
            Porto und Versand. Pay as you go – ohne Grundgebühr.
          </p>
        </div>
        <div class="cta-buttons">
          <a class="btn btn-primary" href={SITE.appRegister} rel="noopener">
            Kostenlos starten
          </a>
          <a class="btn btn-secondary" href="/preise">Preise ansehen</a>
        </div>
      </aside>
    </div>

    {
      related.length > 0 && (
        <section class="related">
          <div class="container">
            <h2>Weiterlesen</h2>
            <div class="related-grid">
              {related.map((rel) => (
                <a class="rel-card card" href={`/blog/${rel.id}`}>
                  <div class="rel-media">
                    <Image
                      src={rel.data.cover}
                      alt={rel.data.coverAlt}
                      widths={[360, 560]}
                      sizes="(max-width: 680px) 100vw, 33vw"
                      loading="lazy"
                    />
                  </div>
                  <div class="rel-body">
                    <span class="cat">{rel.data.category}</span>
                    <h3>{rel.data.title}</h3>
                    <span class="readmore">
                      Lesen <Icon name="arrow-right" size={15} />
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .article-head {
    padding: clamp(2.5rem, 2rem + 2vw, 4rem) 0 1.6rem;
    background:
      radial-gradient(700px 420px at 50% -30%, var(--blue-050) 0%, transparent 65%),
      linear-gradient(180deg, #fdfdff 0%, #ffffff 100%);
  }
  .crumbs {
    display: flex;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--slate-400);
    margin-bottom: 1.4rem;
  }
  .crumbs a {
    color: var(--slate-500);
  }
  .crumbs .current {
    color: var(--slate-400);
  }
  .article-head h1 {
    font-size: clamp(1.8rem, 1.3rem + 2.2vw, 2.7rem);
  }
  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--slate-500);
    font-size: 0.92rem;
    margin: 1.1rem 0 0;
  }
  .cat {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--blue-deep);
    background: var(--blue-050);
    border: 1px solid var(--blue-100);
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
  }
  .dot {
    color: var(--slate-300);
  }

  .article-cover {
    margin: 1.6rem 0 2.4rem;
  }
  .article-cover :global(img) {
    border-radius: var(--r-lg);
    border: 1px solid var(--slate-200);
    box-shadow: var(--shadow-md);
    width: 100%;
    height: auto;
  }

  /* Artikel-Typografie: PT Serif für angenehmes Langlesen */
  .article-prose {
    font-family: var(--font-serif);
    font-size: 1.11rem;
    line-height: 1.78;
    color: #2a3342;
  }
  .article-prose :global(h2),
  .article-prose :global(h3) {
    font-family: var(--font-head);
  }
  .article-prose :global(code) {
    font-size: 0.85em;
  }
  .article-prose :global(pre) {
    background: var(--slate-050);
    border: 1px solid var(--slate-200);
    border-radius: var(--r-md);
    padding: 1rem 1.2rem;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .article-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .article-faq {
    margin-top: 3.5rem;
  }
  .article-faq h2 {
    text-align: center;
    margin-bottom: 1.6rem;
  }

  .article-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 3.5rem 0 0;
    padding: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem);
    border-radius: var(--r-xl);
    background:
      radial-gradient(400px 200px at 100% 0%, var(--blue-050), transparent 70%),
      #fff;
  }
  .article-cta h2 {
    font-size: 1.35rem;
    margin-bottom: 0.35em;
  }
  .article-cta p {
    color: var(--slate-600);
    margin: 0;
    max-width: 46ch;
  }
  .cta-buttons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .related {
    padding: clamp(3rem, 2.5rem + 2vw, 4.5rem) 0 clamp(3.5rem, 3rem + 2vw, 5rem);
    background: var(--slate-050);
    margin-top: clamp(3rem, 2.5rem + 2vw, 4.5rem);
  }
  .related h2 {
    margin-bottom: 1.6rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }
  .rel-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .rel-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .rel-media {
    aspect-ratio: 16 / 9;
    background: #f4f6fb;
  }
  .rel-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rel-body {
    padding: 1.2rem 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .rel-body .cat {
    align-self: flex-start;
  }
  .rel-body h3 {
    font-size: 1.02rem;
    margin: 0;
  }
  .readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--blue);
    margin-top: auto;
  }
  @media (max-width: 780px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
