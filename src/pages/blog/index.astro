---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHead from '../../components/SectionHead.astro';
import CTABand from '../../components/CTABand.astro';
import Icon from '../../components/Icon.astro';
import { SITE } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;

const dateFmt = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const readingTime = (body: string | undefined) =>
  Math.max(2, Math.round((body ?? '').split(/\s+/).length / 200));

const title = 'Blog: Wissen rund um Briefversand, E-Post & Direktmailing | versendio';
const description =
  'Praxiswissen für moderne Geschäftspost: Anleitungen und Tipps zu Online-Briefversand, Serienbriefen, Rechnungsversand, DSGVO und Direktmailings.';

const blogLd = {
  '@type': 'Blog',
  '@id': `${SITE.url}/blog#blog`,
  name: 'versendio Blog',
  description,
  url: `${SITE.url}/blog`,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'de-DE',
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    url: `${SITE.url}/blog/${post.id}`,
    datePublished: post.data.pubDate.toISOString(),
  })),
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={[blogLd, breadcrumbLd]}>
  <section class="page-hero">
    <div class="container">
      <SectionHead
        as="h1"
        eyebrow="Blog"
        title="Wissen für <em>moderne Geschäftspost</em>"
        lead="Anleitungen, Praxis-Tipps und Hintergründe rund um Briefversand, Serienbriefe, Rechnungen und Direktmailings."
      />
    </div>
  </section>

  <section class="section blog-section">
    <div class="container">
      {
        featured && (
          <a class="featured card" href={`/blog/${featured.id}`}>
            <div class="featured-media">
              <Image
                src={featured.data.cover}
                alt={featured.data.coverAlt}
                widths={[480, 800, 1100]}
                sizes="(max-width: 900px) 100vw, 60vw"
                loading="eager"
              />
            </div>
            <div class="featured-body">
              <p class="meta">
                <span class="cat">{featured.data.category}</span>
                <time datetime={featured.data.pubDate.toISOString()}>
                  {dateFmt.format(featured.data.pubDate)}
                </time>
                <span class="dot">·</span>
                {readingTime(featured.body)} Min. Lesezeit
              </p>
              <h2>{featured.data.title}</h2>
              <p class="excerpt">{featured.data.description}</p>
              <span class="readmore">
                Artikel lesen <Icon name="arrow-right" size={17} />
              </span>
            </div>
          </a>
        )
      }

      <div class="post-grid">
        {
          rest.map((post) => (
            <a class="post card" href={`/blog/${post.id}`}>
              <div class="post-media">
                <Image
                  src={post.data.cover}
                  alt={post.data.coverAlt}
                  widths={[400, 640, 900]}
                  sizes="(max-width: 640px) 100vw, (max-width: 980px) 50vw, 33vw"
                  loading="lazy"
                />
              </div>
              <div class="post-body">
                <p class="meta">
                  <span class="cat">{post.data.category}</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {dateFmt.format(post.data.pubDate)}
                  </time>
                </p>
                <h2>{post.data.title}</h2>
                <p class="excerpt">{post.data.description}</p>
                <span class="readmore">
                  Artikel lesen <Icon name="arrow-right" size={16} />
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    title="Lieber machen statt lesen?"
    text="Registrieren Sie sich kostenlos und versenden Sie Ihren ersten Brief in wenigen Minuten – ohne Abo, ohne Grundgebühr."
  />
</BaseLayout>

<style>
  .page-hero {
    padding: clamp(3rem, 2rem + 3vw, 5rem) 0 0;
    background:
      radial-gradient(700px 420px at 50% -20%, var(--blue-050) 0%, transparent 65%),
      linear-gradient(180deg, #fdfdff 0%, #ffffff 100%);
  }
  .page-hero :global(.section-head) {
    margin-bottom: 1rem;
  }
  .blog-section {
    padding-top: clamp(2rem, 1.5rem + 2vw, 3rem);
  }

  a.card {
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  a.card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .featured {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    margin-bottom: 2.2rem;
  }
  .featured-media,
  .post-media {
    background: #f4f6fb;
  }
  .featured-media :global(img),
  .post-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .featured-body {
    padding: clamp(1.6rem, 1.2rem + 1.5vw, 2.6rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .featured h2 {
    font-size: clamp(1.4rem, 1.2rem + 1vw, 1.9rem);
    margin-bottom: 0.5em;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-size: 0.87rem;
    color: var(--slate-500);
    margin-bottom: 0.9rem;
  }
  .cat {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--blue-deep);
    background: var(--blue-050);
    border: 1px solid var(--blue-100);
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
  }
  .dot {
    color: var(--slate-300);
  }

  .excerpt {
    color: var(--slate-600);
    font-size: 0.99rem;
    margin-bottom: 1.2rem;
  }

  .readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--blue);
    margin-top: auto;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.6rem;
  }
  .post {
    display: flex;
    flex-direction: column;
  }
  .post-media {
    aspect-ratio: 16 / 9;
  }
  .post-body {
    padding: 1.5rem 1.6rem 1.6rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .post h2 {
    font-size: 1.22rem;
    margin-bottom: 0.45em;
  }
  .post .excerpt {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .featured {
      grid-template-columns: 1fr;
    }
    .featured-media {
      aspect-ratio: 16 / 9;
    }
  }
  @media (max-width: 680px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
