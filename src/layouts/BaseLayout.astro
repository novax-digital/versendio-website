---
import '../styles/global.css';
import Banner from '../components/Banner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, COMPANY } from '../data/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** Seitenspezifische JSON-LD-Objekte (werden in den @graph gemerged) */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage = SITE.ogImage,
  ogType = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;

const pathname = Astro.url.pathname;
const canonical = new URL(
  pathname === '/' ? '/' : pathname.replace(/\/+$/, ''),
  Astro.site,
);
const ogImageUrl = new URL(ogImage, Astro.site);

const organizationLd = {
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  legalName: COMPANY.name,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/appicon-512.png`,
    width: 512,
    height: 512,
  },
  email: SITE.email,
  telephone: '+49 511 90121885',
  address: {
    '@type': 'PostalAddress',
    streetAddress: COMPANY.street,
    postalCode: COMPANY.zip,
    addressLocality: COMPANY.city,
    addressCountry: COMPANY.countryCode,
  },
};

const websiteLd = {
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'de-DE',
};

const graph = {
  '@context': 'https://schema.org',
  '@graph': [organizationLd, websiteLd, ...jsonLd],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />

    <link
      rel="preload"
      href="/fonts/poppins-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/lato-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="versendio Blog"
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>
    <Banner />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -60px;
    left: 16px;
    z-index: 200;
    background: var(--ink);
    color: #fff;
    padding: 0.7rem 1.1rem;
    border-radius: 0 0 10px 10px;
    font-family: var(--font-head);
    font-weight: 600;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
