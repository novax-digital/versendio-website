---
import LogoSvg from '../assets/versendio-logo.svg';
import Icon from './Icon.astro';
import { SITE, NAV, type NavItem } from '../data/site';

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
const hasChildren = (
  item: NavItem,
): item is Extract<NavItem, { children: unknown }> => 'children' in item;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="versendio – zur Startseite">
      <LogoSvg width={132} height={30} />
    </a>

    <nav class="main-nav" aria-label="Hauptnavigation">
      {
        NAV.map((item) =>
          hasChildren(item) ? (
            <div class="nav-item">
              <a
                href={item.href}
                class:list={['nav-link', 'has-sub', { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
                <Icon name="chevron-down" size={15} strokeWidth={2.2} class="nav-caret" />
              </a>
              <div class="dropdown">
                <div class="dropdown-panel">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={['dd-link', { active: isActive(child.href) }]}
                      aria-current={isActive(child.href) ? 'page' : undefined}
                    >
                      <span class="dd-icon">
                        <Icon name={child.icon} size={18} />
                      </span>
                      <span class="dd-copy">
                        <span class="dd-label">{child.label}</span>
                        <span class="dd-desc">{child.description}</span>
                      </span>
                    </a>
                  ))}
                  <a href={item.href} class="dd-all">
                    Alle Lösungen im Überblick <Icon name="arrow-right" size={15} />
                  </a>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="header-cta">
      <a class="btn btn-ghost btn-sm" href={SITE.appLogin} rel="noopener">Anmelden</a>
      <a class="btn btn-primary btn-sm" href={SITE.appRegister} rel="noopener">
        Kostenlos starten
      </a>
    </div>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Menü öffnen"
    >
      <span class="icon-menu"><Icon name="menu" size={24} /></span>
      <span class="icon-close"><Icon name="x" size={24} /></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <nav aria-label="Mobile Navigation">
      {
        NAV.map((item) =>
          hasChildren(item) ? (
            <div class="mobile-group">
              <a href={item.href} class:list={['mobile-link', { active: isActive(item.href) }]}>
                {item.label}
              </a>
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={['mobile-sublink', { active: isActive(child.href) }]}
                >
                  <Icon name={child.icon} size={16} />
                  {child.label}
                </a>
              ))}
            </div>
          ) : (
            <a href={item.href} class:list={['mobile-link', { active: isActive(item.href) }]}>
              {item.label}
            </a>
          ),
        )
      }
    </nav>
    <div class="mobile-cta">
      <a class="btn btn-secondary" href={SITE.appLogin} rel="noopener">Anmelden</a>
      <a class="btn btn-primary" href={SITE.appRegister} rel="noopener">Kostenlos starten</a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Menü öffnen' : 'Menü schließen');
    if (mobileNav) mobileNav.hidden = open;
    document.body.classList.toggle('nav-open', !open);
  });

  const onScroll = () => {
    header?.classList.toggle('scrolled', window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .site-header.scrolled {
    border-bottom-color: var(--slate-200);
    box-shadow: 0 1px 12px rgba(16, 24, 40, 0.05);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: var(--header-h);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .main-nav {
    display: flex;
    gap: 0.4rem;
    margin-left: 0.8rem;
    margin-right: auto;
  }

  .nav-link {
    font-family: var(--font-head);
    font-size: 0.97rem;
    font-weight: 400;
    color: var(--slate-600);
    padding: 0.5rem 0.85rem;
    border-radius: var(--r-sm);
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav-link:hover {
    color: var(--ink);
    background: var(--slate-100);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--blue);
    font-weight: 600;
  }

  /* ---- Dropdown (Lösungen) ---- */
  .nav-item {
    position: relative;
  }
  .nav-link.has-sub {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .nav-link.has-sub :global(.nav-caret) {
    color: var(--slate-400);
    transition: transform 0.18s ease;
  }
  .nav-item:hover .nav-link.has-sub :global(.nav-caret),
  .nav-item:focus-within .nav-link.has-sub :global(.nav-caret) {
    transform: rotate(180deg);
  }

  .dropdown {
    position: absolute;
    top: 100%;
    left: -0.4rem;
    padding-top: 0.55rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.16s ease, transform 0.16s ease, visibility 0.16s;
    z-index: 60;
  }
  .nav-item:hover .dropdown,
  .nav-item:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-panel {
    width: 340px;
    background: #fff;
    border: 1px solid var(--slate-200);
    border-radius: 14px;
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    display: grid;
    gap: 2px;
  }
  .dd-link {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.62rem 0.65rem;
    border-radius: 10px;
    transition: background-color 0.14s ease;
  }
  .dd-link:hover {
    background: var(--slate-050);
    text-decoration: none;
  }
  .dd-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 9px;
    background: var(--blue-050);
    border: 1px solid var(--blue-100);
    color: var(--blue);
    flex-shrink: 0;
  }
  .dd-copy {
    min-width: 0;
  }
  .dd-label {
    display: block;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.93rem;
    color: var(--ink);
    line-height: 1.3;
  }
  .dd-link.active .dd-label {
    color: var(--blue);
  }
  .dd-desc {
    display: block;
    font-size: 0.83rem;
    color: var(--slate-500);
    line-height: 1.35;
    margin-top: 1px;
  }
  .dd-all {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.3rem;
    padding: 0.7rem 0.65rem 0.45rem;
    border-top: 1px solid var(--slate-100);
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--blue);
  }
  .dd-all:hover {
    color: var(--blue-deep);
    text-decoration: none;
  }
  .dd-all :global(svg) {
    transition: transform 0.16s ease;
  }
  .dd-all:hover :global(svg) {
    transform: translateX(3px);
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  :global(.btn-sm) {
    padding: 0.68rem 1.15rem;
    font-size: 0.95rem;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--ink);
    padding: 0.5rem;
    margin-left: auto;
    cursor: pointer;
  }
  .nav-toggle .icon-close,
  .nav-toggle[aria-expanded='true'] .icon-menu {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  .mobile-nav {
    display: none;
    border-top: 1px solid var(--slate-200);
    background: #fff;
    padding: 1rem clamp(1.1rem, 4vw, 2rem) 1.4rem;
  }
  .mobile-nav nav {
    display: flex;
    flex-direction: column;
  }
  .mobile-link {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--ink);
    padding: 0.8rem 0.2rem;
    border-bottom: 1px solid var(--slate-100);
  }
  .mobile-link.active {
    color: var(--blue);
  }
  .mobile-group {
    display: flex;
    flex-direction: column;
  }
  .mobile-sublink {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-head);
    font-size: 0.98rem;
    color: var(--slate-600);
    padding: 0.6rem 0.2rem 0.6rem 1.1rem;
    border-bottom: 1px solid var(--slate-100);
  }
  .mobile-sublink :global(svg) {
    color: var(--slate-400);
    flex-shrink: 0;
  }
  .mobile-sublink.active {
    color: var(--blue);
    font-weight: 600;
  }
  .mobile-sublink.active :global(svg) {
    color: var(--blue);
  }
  .mobile-cta {
    display: grid;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }

  @media (max-width: 860px) {
    .main-nav,
    .header-cta {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .mobile-nav:not([hidden]) {
      display: block;
    }
  }
</style>
